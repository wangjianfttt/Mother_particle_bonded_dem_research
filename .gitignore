.DS_Store
.mplconfig/
external/
*.log
*.liggghts
*.vtk
*.dump

# Large DEM runtime outputs and restart states.
**/post/
**/restart*.data
**/*.restart
**/*.local
**/*.dump
**/*.vtk
**/*.vtp
**/*.vtu
**/*.stl.tmp
*.pid

# Local run logs produced during screening and calibration.
logs_*.out
screen_driver_*.out
nohup.out

# LaTeX build by-products; keep committed/exported PDFs separately.
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.out
*.run.xml
*.synctex.gz
*.xdv

# Python/editor caches.
__pycache__/
*.py[cod]
.ipynb_checkpoints/

# Keep public submission bundles explicit; avoid accidental raw package staging.
*.tmp
