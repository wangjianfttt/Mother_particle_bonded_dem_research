fix             m3 all property/global coefficientRestitution peratomtypepair 3                 0.3 0.3 0.3 0.3 0.3 0.3 0.3 0.3 ${cor}
fix             m3 all property/global coefficientRestitution peratomtypepair 3                 0.3 0.3 0.3 0.3 0.3 0.3 0.3 0.3 0.3
fix             m4 all property/global coefficientFriction peratomtypepair 3                 ${mu} ${mu} ${mu} ${mu} ${mu} ${mu} ${mu} ${mu} ${mu}
