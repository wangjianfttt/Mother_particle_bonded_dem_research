LIGGGHTS (Version LIGGGHTS-INL 4.0.0, compiled 2026-06-04-16:17:41 by wangjian-macbook13, git commit d69df361fc9b0a78ba09a50242bc76552d9bd71e)
echo            both
units           si
atom_style      granular
atom_modify     map array
atom_modify     sort 0 0.0
boundary        f f f
newton          off
communicate     mode single vel yes
processors      * * 1
hard_particles  yes
soft_particles  yes

variable        hold_steps      index 40000
variable        rho             equal 2400.0
variable        young           index 5.0e6
variable        poisson         equal 0.25
variable        cor             equal 0.3
variable        mu              equal 0.5
variable        rb_mult         equal 1.0
variable        kn_bond         index 1.0e14
variable        kt_bond         index 5.0e13
variable        sigma_bulk      index 9.0e7
variable        tau_bulk        index 9.0e7
variable        sigma_weak      index 2.25e7
variable        tau_weak        index 2.25e7
variable        create_dist     equal 2.00e-4
variable        create_weak     equal 9.00e-5

read_restart    post/seated_final.restart
  orthogonal box = (-0.03 -0.03 -0.03) to (0.03 0.03 0.08)
  1 by 1 by 1 MPI processor grid
  50000 atoms
neighbor        1.0e-4 bin
neigh_modify    delay 0

fix             m1 all property/global youngsModulus peratomtype ${young} ${young} ${young}
fix             m1 all property/global youngsModulus peratomtype 5.0e6 ${young} ${young}
fix             m1 all property/global youngsModulus peratomtype 5.0e6 5.0e6 ${young}
fix             m1 all property/global youngsModulus peratomtype 5.0e6 5.0e6 5.0e6
fix             m2 all property/global poissonsRatio peratomtype ${poisson} ${poisson} ${poisson}
fix             m2 all property/global poissonsRatio peratomtype 0.25 ${poisson} ${poisson}
fix             m2 all property/global poissonsRatio peratomtype 0.25 0.25 ${poisson}
fix             m2 all property/global poissonsRatio peratomtype 0.25 0.25 0.25
fix             m3 all property/global coefficientRestitution peratomtypepair 3                 ${cor} ${cor} ${cor} ${cor} ${cor} ${cor} ${cor} ${cor} ${cor}
fix             m3 all property/global coefficientRestitution peratomtypepair 3                 0.3 ${cor} ${cor} ${cor} ${cor} ${cor} ${cor} ${cor} ${cor}
fix             m3 all property/global coefficientRestitution peratomtypepair 3                 0.3 0.3 ${cor} ${cor} ${cor} ${cor} ${cor} ${cor} ${cor}
