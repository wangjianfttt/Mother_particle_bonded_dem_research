fix             integrate all nve/sphere
fix             grav all gravity 9.81 vector 0.0 0.0 -1.0
fix             damp all viscous 2.0e-5
compute         bond_status all bond/counter
compute         pair_contacts all pair/gran/local id force force_normal delta
compute         wall_contacts all wall/gran/local id force force_normal delta

variable        top_force equal f_mesh_top[3]
variable        bottom_force equal f_mesh_bottom[3]
variable        side_force equal f_mesh_xlo[3]+f_mesh_xhi[3]+f_mesh_ylo[3]+f_mesh_yhi[3]
variable        bond_created equal c_bond_status[1]
variable        bond_broken equal c_bond_status[2]
variable        bond_intact equal c_bond_status[3]

thermo_style    custom step atoms ke v_top_force v_bottom_force v_side_force                 v_bond_created v_bond_broken v_bond_intact
thermo          500
thermo_modify   lost ignore norm no flush yes

run             ${hold_steps}
run             500
